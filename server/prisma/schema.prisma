generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ValidationRun {
  id           String            @id @default(uuid())
  fileName     String
  fileType     String            @default("CUSTOMER")
  totalRows    Int
  errors       Int
  warnings     Int
  info         Int
  // Stores original row data for rows that have at least one issue,
  // enabling the "Original Rows With Issues" Excel sheet without keeping the full CSV.
  affectedRows Json?
  createdAt    DateTime          @default(now())
  issues       ValidationIssue[]

  @@map("validation_runs")
}

model ValidationIssue {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  columnName      String
  severity        String
  issueType       String
  currentValue    String?
  message         String
  suggestedFix    String?
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("validation_issues")
}
