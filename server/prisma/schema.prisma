generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ValidationRun {
  id              String                @id @default(uuid())
  fileName        String
  fileType        String                @default("CUSTOMER")
  totalRows       Int
  errors          Int
  warnings        Int
  info            Int
  affectedRows    Json?
  originalColumns Json?
  columnMapping   Json?
  ticketNumber    String?
  ticketName      String?
  comments        String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  issues          ValidationIssue[]
  originalRows    OriginalCustomerRow[]

  @@map("validation_runs")
}

model OriginalCustomerRow {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  data            Json
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("original_customer_rows")
}

model ValidationIssue {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  columnName      String
  severity        String
  issueType       String
  currentValue    String?
  message         String
  suggestedFix    String?
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("validation_issues")
}
