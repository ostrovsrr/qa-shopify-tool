generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ValidationRun {
  id              String                @id @default(uuid())
  fileName        String
  fileType        String                @default("CUSTOMER")
  totalRows       Int
  errors          Int
  warnings        Int
  info            Int
  affectedRows    Json?
  originalColumns Json?
  columnMapping      Json?
  heliosMigratedTag  Boolean               @default(false)
  ticketNumber       String?
  ticketName      String?
  comments        String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  issues          ValidationIssue[]
  originalRows    OriginalCustomerRow[]
  importRuns      ImportRun[]

  @@map("validation_runs")
}

model ImportRun {
  id              String            @id @default(uuid())
  validationId    String
  // storeId lets a later reconcile rebuild the Shopify client (getShopifyClient(storeId))
  // when finalizing an async run; null falls back to the default store. Also null for
  // a batch parent run, whose stores live on its ImportBatchJob children.
  storeId         String?
  shopDomain      String
  // Null for a batch parent (the bulk ops live on its ImportBatchJob children);
  // set for a normal single-store run.
  bulkOperationId String?
  // RUNNING (start persisted, bulk op queued) → COMPLETED | FAILED | CANCELED | EXPIRED
  status          String            @default("RUNNING")
  // Failure reason for the terminal error states; null while RUNNING/COMPLETED.
  error           String?
  successCount    Int               @default(0)
  errorCount      Int               @default(0)
  createdAt       DateTime          @default(now())

  validationRun ValidationRun     @relation(fields: [validationId], references: [id], onDelete: Cascade)
  rowResults    ImportRowResult[]
  batchJobs     ImportBatchJob[]

  @@index([validationId])
  @@map("import_runs")
}

// One per-store bulk operation within a parallel batch import. The parent
// ImportRun owns the merged rowResults; each job tracks its own store's bulk op
// and the contiguous row slice it imported (recomputed from batchIndex/batchCount).
model ImportBatchJob {
  id              String   @id @default(uuid())
  importRunId     String
  storeId         String?
  shopDomain      String
  batchIndex      Int
  batchCount      Int
  // Null when the job failed to even start (e.g. store unhealthy at launch).
  bulkOperationId String?
  status          String   @default("RUNNING")
  error           String?
  rowCount        Int      @default(0)
  successCount    Int      @default(0)
  errorCount      Int      @default(0)
  // Times the reconcile poll has checked this job while non-terminal; a stuck job
  // (perma-RUNNING or repeatedly erroring) is failed once it exceeds the max.
  pollAttempts    Int      @default(0)
  createdAt       DateTime @default(now())

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@map("import_batch_jobs")
}

model ImportRowResult {
  id                    String   @id @default(uuid())
  importRunId           String
  rowNumber             Int
  accepted              Boolean
  shopifyCustomerId     String?
  shopifyCode           String?
  shopifyField          String?
  message               String?
  // Which store imported this row — null for legacy rows; for a batch it's the
  // job's store, enabling the per-store accepted/rejected breakdown.
  storeId               String?
  // Set at join time so the four-bucket query is a single lookup.
  wasFlaggedByValidator Boolean  @default(false)
  createdAt             DateTime @default(now())

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@index([accepted, wasFlaggedByValidator])
  @@map("import_row_results")
}

model OriginalCustomerRow {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  data            Json
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("original_customer_rows")
}

model ValidationIssue {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  columnName      String
  severity        String
  issueType       String
  currentValue    String?
  message         String
  suggestedFix    String?
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("validation_issues")
}
