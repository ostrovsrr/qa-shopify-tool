generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTRIBUTION IS NOT AUTHORIZATION.
//
// `createdBy` exists so a colleague can find their own run in a shared history, and
// so the destructive-action log names a person. It is for DISPLAY and AUDIT.
//
// It MUST NEVER appear in a WHERE clause that gates access. The moment it does, it
// has become an authorization mechanism — one that arrived through the back door
// with none of the tests, none of the threat model, and none of the review that a
// real one would get. The tool is a deliberately SHARED workspace (decision
// 7a56f7f2): everybody sees every run. If that ever changes, it changes as a
// designed feature, not as a filter someone added to a query.
//
// Until Cloudflare Access lands, the value is supplied by the CLIENT and is
// therefore trivially spoofable. That is fine for the thing it is for (knowing who
// to ask about a run) and disqualifying for anything else.
// ─────────────────────────────────────────────────────────────────────────────

model ValidationRun {
  id              String                @id @default(uuid())
  // Who uploaded this. Display + audit ONLY — see the note above.
  createdBy       String?
  // When the raw uploaded rows were purged for retention (D13). Non-null means the
  // run's aggregate results survive but the source rows are gone, so the Excel
  // report can no longer be rebuilt and the UI says so rather than erroring.
  piiPurgedAt     DateTime?
  fileName        String
  fileType        String                @default("CUSTOMER")
  totalRows       Int
  errors          Int
  warnings        Int
  info            Int
  affectedRows    Json?
  originalColumns Json?
  columnMapping      Json?
  heliosMigratedTag  Boolean               @default(false)
  // When on, the Shopify Template sheet strips the duplicated email/phone from
  // 2nd+ occurrences of a duplicate group and appends the value to Note instead,
  // so Shopify still accepts the customer on import.
  moveDuplicatesToNotes Boolean            @default(false)
  // When on, duplicate-group rows whose names also match are merged into one
  // customer row in the Shopify Template sheet (most-filled row wins).
  mergeMatchingDuplicates Boolean          @default(false)
  ticketNumber       String?
  ticketName      String?
  comments        String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  issues          ValidationIssue[]
  originalRows    OriginalCustomerRow[]
  importRuns      ImportRun[]

  @@map("validation_runs")
}

model ImportRun {
  id              String            @id @default(uuid())
  validationId    String
  // storeId lets a later reconcile rebuild the Shopify client (getShopifyClient(storeId))
  // when finalizing an async run; null falls back to the default store. Also null for
  // a batch parent run, whose stores live on its ImportBatchJob children.
  storeId         String?
  shopDomain      String
  // Null for a batch parent (the bulk ops live on its ImportBatchJob children);
  // set for a normal single-store run.
  bulkOperationId String?
  // PENDING (row written, bulk op NOT yet submitted) → RUNNING (op queued) →
  // COMPLETED | FAILED | CANCELED | EXPIRED.
  //
  // PENDING exists so we never take a side effect we have not recorded: the row
  // lands BEFORE the bulk op is submitted. A crash in between therefore leaves a
  // PENDING row (recoverable) instead of an untracked bulk op creating real
  // records in a real store with no trace of the run.
  status          String            @default("RUNNING")
  // Failure reason for the terminal error states; null while RUNNING/COMPLETED.
  error           String?
  successCount    Int               @default(0)
  errorCount      Int               @default(0)
  // Set when resume-on-boot takes ownership of a PENDING row, so two overlapping
  // boots (a rolling deploy) cannot work the same row twice. A claim older than
  // the stale threshold is reclaimable — otherwise a process killed mid-claim
  // would strand the row forever, trading a wrong answer for a permanent hang.
  claimedAt       DateTime?
  createdAt       DateTime          @default(now())

  validationRun ValidationRun     @relation(fields: [validationId], references: [id], onDelete: Cascade)
  rowResults    ImportRowResult[]
  batchJobs     ImportBatchJob[]

  @@index([validationId])
  @@map("import_runs")
}

// One per-store bulk operation within a parallel batch import. The parent
// ImportRun owns the merged rowResults; each job tracks its own store's bulk op
// and the contiguous row slice it imported (recomputed from batchIndex/batchCount).
model ImportBatchJob {
  id              String   @id @default(uuid())
  importRunId     String
  storeId         String?
  shopDomain      String
  batchIndex      Int
  batchCount      Int
  // Null when the job failed to even start (e.g. store unhealthy at launch).
  bulkOperationId String?
  // PENDING (row written, bulk op NOT yet submitted) → RUNNING → terminal.
  // ALL jobs in a batch are written as PENDING in the parent's transaction before
  // the fan-out starts. PENDING is not terminal, so an unstarted job holds the
  // parent's rollup open — that is what stops a crash mid-fan-out from reporting
  // a successful import of stores that never received anything.
  status          String   @default("RUNNING")
  error           String?
  rowCount        Int      @default(0)
  successCount    Int      @default(0)
  errorCount      Int      @default(0)
  // Times the reconcile poll has checked this job while non-terminal; a stuck job
  // (perma-RUNNING or repeatedly erroring) is failed once it exceeds the max.
  pollAttempts    Int      @default(0)
  // See ImportRun.claimedAt.
  claimedAt       DateTime?
  createdAt       DateTime @default(now())

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@map("import_batch_jobs")
}

model ImportRowResult {
  id                    String   @id @default(uuid())
  importRunId           String
  rowNumber             Int
  accepted              Boolean
  shopifyCustomerId     String?
  shopifyCode           String?
  shopifyField          String?
  message               String?
  // Which store imported this row — null for legacy rows; for a batch it's the
  // job's store, enabling the per-store accepted/rejected breakdown.
  storeId               String?
  // Set at join time so the four-bucket query is a single lookup.
  wasFlaggedByValidator Boolean  @default(false)
  createdAt             DateTime @default(now())

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@index([accepted, wasFlaggedByValidator])
  @@map("import_row_results")
}

model OriginalCustomerRow {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  data            Json
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("original_customer_rows")
}

model ValidationIssue {
  id              String        @id @default(uuid())
  validationRunId String
  rowNumber       Int
  columnName      String
  severity        String
  issueType       String
  currentValue    String?
  message         String
  suggestedFix    String?
  createdAt       DateTime      @default(now())

  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: Cascade)

  @@map("validation_issues")
}

// ── Products ──

// One CSV upload. The product CSV is already in Shopify template format, so there
// is no validation/mapping step — we just persist what was uploaded, grouped by
// Handle into products, and let the import be the truth.
model ProductUploadRun {
  id              String   @id @default(uuid())
  // Display + audit ONLY. See the note above ValidationRun — the same rule applies,
  // because customers and products are twins.
  createdBy       String?
  // See ValidationRun.piiPurgedAt.
  piiPurgedAt     DateTime?
  fileName        String
  // Number of products = distinct Handles in the CSV (the import unit), not rows.
  productCount    Int
  // The CSV header row, in order, so the original file shape is recoverable.
  originalColumns Json?
  ticketNumber    String?
  ticketName      String?
  comments        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  originalRows ProductOriginalRow[]
  importRuns   ProductImportRun[]

  @@map("product_upload_runs")
}

// One import attempt of an upload into Shopify. For a single-store run this owns
// the bulk op directly; for a parallel batch it is the parent that owns the merged
// rowResults while the per-store bulk ops live on its ProductImportJob children.
model ProductImportRun {
  id           String @id @default(uuid())
  uploadId     String
  // storeId lets a later reconcile rebuild the Shopify client (getShopifyClient(storeId))
  // when finalizing an async run; null falls back to the default store. Also null for
  // a batch parent run, whose stores live on its ProductImportJob children.
  storeId      String?
  shopDomain   String
  // Null for a batch parent (the bulk ops live on its ProductImportJob children);
  // set for a normal single-store run.
  bulkOperationId String?
  // PENDING (row written, bulk op NOT yet submitted) → RUNNING (op queued) →
  // COMPLETED | FAILED | CANCELED | EXPIRED. See ImportRun.status — the customer
  // and product flows are twins and share this state machine.
  status       String  @default("RUNNING")
  // Failure reason for the terminal error states; null while RUNNING/COMPLETED.
  error        String?
  successCount Int     @default(0)
  errorCount   Int     @default(0)
  // See ImportRun.claimedAt.
  claimedAt    DateTime?
  createdAt    DateTime @default(now())

  uploadRun  ProductUploadRun      @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  rowResults ProductImportResult[]
  batchJobs  ProductImportJob[]

  @@index([uploadId])
  @@map("product_import_runs")
}

// One per-store bulk operation within a parallel batch import. The parent
// ProductImportRun owns the merged rowResults; each job tracks its own store's
// bulk op and the contiguous product slice it imported (recomputed from
// batchIndex/batchCount).
model ProductImportJob {
  id              String  @id @default(uuid())
  importRunId     String
  storeId         String?
  shopDomain      String
  batchIndex      Int
  batchCount      Int
  // Null when the job failed to even start (e.g. store unhealthy at launch).
  bulkOperationId String?
  // PENDING → RUNNING → terminal. See ImportBatchJob.status: all jobs are written
  // as PENDING in the parent's transaction before the fan-out, so an unstarted job
  // holds the parent's rollup open and a partial fan-out cannot claim success.
  status          String  @default("RUNNING")
  error           String?
  // Counted in products, not CSV rows.
  productCount    Int     @default(0)
  successCount    Int     @default(0)
  errorCount      Int     @default(0)
  // Times the reconcile poll has checked this job while non-terminal; a stuck job
  // (perma-RUNNING or repeatedly erroring) is failed once it exceeds the max.
  pollAttempts    Int     @default(0)
  // See ImportRun.claimedAt.
  claimedAt       DateTime?
  createdAt       DateTime @default(now())

  importRun ProductImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@map("product_import_jobs")
}

// One result per product (keyed by Handle). The report groups rejections by
// (shopifyField, shopifyCode) directly off the real productSet userError code.
model ProductImportResult {
  id               String  @id @default(uuid())
  importRunId      String
  handle           String
  accepted         Boolean
  shopifyProductId String?
  shopifyCode      String?
  shopifyField     String?
  message          String?
  // Which store imported this product — for a batch it's the job's store, enabling
  // the per-store accepted/rejected breakdown; null for a single-store run.
  storeId          String?
  createdAt        DateTime @default(now())

  importRun ProductImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@map("product_import_results")
}

// The raw CSV rows for an upload, preserved in order so the original product CSV
// is recoverable and groupable by Handle for input building.
model ProductOriginalRow {
  id          String @id @default(uuid())
  uploadRunId String
  rowNumber   Int
  data        Json
  createdAt   DateTime @default(now())

  uploadRun ProductUploadRun @relation(fields: [uploadRunId], references: [id], onDelete: Cascade)

  @@index([uploadRunId])
  @@map("product_original_rows")
}

// Append-only record of every DESTRUCTIVE action, so "who deleted the QA products
// I was halfway through checking?" has an answer.
//
// The tool has six routes that destroy things: deleting a validation run, deleting a
// product upload, the two whole-store QA cleanups, and the two run-scoped cleanups.
// Four of those delete records from a REAL Shopify store, by tag, across the whole
// store. In a shared workspace, any colleague can fire any of them at any store.
//
// This is a LOG, not a permission check. It does not stop anyone doing anything; it
// makes what they did legible afterwards. Nothing reads it to make a decision — see
// the attribution note above ValidationRun.
model ActionLog {
  id        String   @id @default(uuid())
  // Who, per the request. Spoofable until Cloudflare Access lands; useful anyway,
  // because the failure mode this guards against is a mistake, not an attack.
  actor     String
  // 'DELETE_VALIDATION_RUN' | 'DELETE_PRODUCT_UPLOAD' | 'CLEANUP_STORE_CUSTOMERS' |
  // 'CLEANUP_STORE_PRODUCTS' | 'CLEANUP_IMPORT_CUSTOMERS' | 'CLEANUP_IMPORT_PRODUCTS'
  action    String
  // What it was aimed at: a run id, an upload id, or a store id.
  target    String
  // The store, when the action reached Shopify. Null for a database-only delete.
  storeId   String?
  // Anything worth knowing later: the tag deleted, the row count, the run it
  // reversed. Never raw CSV data — this table is not a PII sink.
  detail    Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([storeId])
  @@map("action_log")
}

// One row per BUSY store: the lock that keeps two operations off the same Shopify
// store at once.
//
// The key is the store, not the run and not the entity, for two reasons:
//
//   1. Shopify's own limit is ONE bulk mutation per SHOP — not one per shop per
//      entity. A customer import and a product import aimed at the same store
//      genuinely collide, so a key of (storeId, entity) would let the collision
//      through. The key is bare storeId.
//   2. The cleanup routes delete BY TAG ACROSS AN ENTIRE STORE. A cleanup racing an
//      import to the same store deletes the very records that import is about to
//      reconcile against, and the run then reports garbage. Same store key
//      serializes them for free.
//
// A batch import across N stores takes N locks, one per store, so parallelism
// across DIFFERENT stores is untouched — the lock only bites on the same store.
model StoreLock {
  // One lock per store. The PK IS the mutual exclusion.
  storeId   String   @id @map("store_id")
  // Which table ownerId points at: IMPORT_RUN | IMPORT_JOB | PRODUCT_IMPORT_RUN |
  // PRODUCT_IMPORT_JOB | CLEANUP_RUN. Lets a later acquirer look up the holder and
  // steal the lock if that row has already reached a terminal state — so a missed
  // release cannot wedge a store forever.
  ownerType String   @map("owner_type")
  ownerId   String   @map("owner_id")
  // Human phrase for the busy message ("a customer import", "a product cleanup").
  operation String
  acquiredAt DateTime @default(now()) @map("acquired_at")
  // Backstop for the case the owner row can never reach terminal on its own: a run
  // is only advanced by a status poll, so if the last browser watching it closes,
  // nothing will ever finalize it and the store would stay locked forever. Renewed
  // on every poll, so a live operation never loses its lock.
  expiresAt DateTime @map("expires_at")

  @@index([ownerId])
  @@map("store_locks")
}

// One cleanup attempt against ONE store. Cleanup used to run entirely inside the
// HTTP request, polling Shopify for up to 300s (150 attempts x 2s) — deliberately,
// per the old comment. That cannot work hosted: platform proxies give up around
// 100s, so the request dies while the delete is still running and the user is told
// nothing. Cleanup is now persisted and advanced one step per poll, exactly like an
// import run.
//
// Serves BOTH flows (customers and products are twins); `entity` says which.
model CleanupRun {
  id              String   @id @default(uuid())
  // 'CUSTOMER' | 'PRODUCT'
  entity          String
  storeId         String?
  shopDomain      String
  // The tag whose records are being deleted: the base 'qa-import' for a whole-store
  // teardown, or 'qa-import-<importRunId>' to reverse exactly one import.
  tag             String
  // Set when this cleanup is reversing a specific import run, so the UI can tie
  // them together. Null for a whole-store "Clean QA" sweep.
  importRunId     String?
  // PENDING (row written, bulk delete NOT yet submitted) → RUNNING → COMPLETED |
  // FAILED | CANCELED | EXPIRED. PENDING exists for the same reason it does on
  // imports: never take a side effect you have not recorded. A crash between
  // submitting the delete and saving its id would otherwise leave records being
  // deleted from a real store with no trace of it.
  status          String   @default("PENDING")
  bulkOperationId String?
  error           String?
  // How many tagged records were found; how many Shopify actually deleted.
  found           Int      @default(0)
  deleted         Int      @default(0)
  failedCount     Int      @default(0)
  // The ids Shopify refused to delete, with its reason. [{ id, message }]
  errors          Json?
  // The ids submitted, in order — the bulk result file maps back to them by line.
  // Needed because the reconcile happens in a LATER request than the submit.
  submittedIds    Json?
  pollAttempts    Int      @default(0)
  // See ImportRun.claimedAt.
  claimedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([importRunId])
  @@index([status])
  @@map("cleanup_runs")
}
