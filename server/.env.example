# ── Server environment template ──────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# this template is committed so teammates know what to configure.
#
#   cp .env.example .env
#

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/shopify_csv_qa"

# Port the API listens on (defaults to 3001 if unset).
PORT=3001

# Origin allowed by CORS — the client dev server.
CLIENT_URL=http://localhost:5173

# ── Shopify test stores (optional) ────────────────────────────────────────────
# Only needed to use the "import into test store" feature. These connect to
# TEST stores only. Configure stores with ONE of the three styles below.

# Default Admin API version for all stores (format: YYYY-MM).
SHOPIFY_API_VERSION=2026-01

# Style A — JSON array (recommended for multiple stores). Each store needs a
# `shop` plus either `adminToken` OR `clientId` + `clientSecret`.
# SHOPIFY_TEST_STORES='[{"label":"QA Store 1","shop":"my-test-store.myshopify.com","adminToken":"shpat_xxx"}]'

# Style B — numbered vars, SHOPIFY_SHOP_1 .. SHOPIFY_SHOP_20.
# SHOPIFY_SHOP_1=my-test-store.myshopify.com
# SHOPIFY_STORE_LABEL_1=QA Store 1
# SHOPIFY_ADMIN_TOKEN_1=shpat_xxx
# SHOPIFY_CLIENT_ID_1=
# SHOPIFY_CLIENT_SECRET_1=

# Style C — legacy single store.
# SHOPIFY_SHOP=my-test-store.myshopify.com
# SHOPIFY_STORE_LABEL=Default Test Store
# SHOPIFY_ADMIN_TOKEN=shpat_xxx
