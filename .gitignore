# Dependencies
node_modules/

# Environment variables (never commit real secrets; .env.example is the tracked template)
.env
.env.local
.env.*.local
!.env.example
# Build output
dist/
build/
.next/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal

# Generated Prisma client is usually inside node_modules, so no need to ignore it separately

# Database / local data
*.sqlite
*.sqlite3
*.db

# Excel / CSV working files
*.xlsx
*.xls
*.csv

# Keep sample/import templates if needed
!sample*.csv
!template*.csv
!examples/*.csv
!sample/*.csv

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
.claude/settings.local.json

# TypeScript
*.tsbuildinfo

# Test coverage
coverage/

# Cache
.cache/
.parcel-cache/
.turbo/

# Temporary files
tmp/
temp/
.gstack/
